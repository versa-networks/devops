sd-wan {
    policies {
        sdwan-policy-group Default-Policy {
            rules {
                rule Pathing_Through_Appgate_for_Elevated_Risk_IP_Addresses {
                    description  "Rule that routes elevated risk ip addr through appgate";
                    rule-disable false;
                    match {
                        source {
                            address {
                                address-group-list [ Elevated_Risk_Addresses ];
                            }
                            user {
                                local-database {
                                status disabled;
                            }
                            external-database {
                                status disabled;
                            }
                            user-type any;
                        }
                    }
                }
                set {
                    action           allow;
                    nexthop-address  192.168.1.1;
                    routing-instance RobK-Demo-1-Enterprise;
                    lef {
                        profile-default true;
                        event           never;
                        rate-limit      10;
                    }
                }
            }
        }
    }
}
